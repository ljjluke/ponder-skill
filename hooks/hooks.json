{
  "description": "Ponder hooks — Setup/SessionStart/SessionEnd via bootstrap-hook.js. agent-reach checked every start, installed on Setup.",
  "hooks": {
    "Setup": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs'),path=require('path'),os=require('os');const b=os.homedir()+'/.claude/plugins/cache';let c=null;for(const n of['luke','mcts','mcts-td-planner']){const d=path.join(b,n,n);if(fs.existsSync(d)){c=d;break}}if(c){let v;try{v=fs.readdirSync(c).filter(x=>{try{return fs.statSync(path.join(c,x)).isDirectory()&&/^\\d+\\.\\d+\\.\\d+$/.test(x)}catch(e){return false}}).sort((a,b)=>{const[a1,a2,a3]=a.split('.').map(Number),[b1,b2,b3]=b.split('.').map(Number);return b1-a1||b2-a2||b3-a3})[0]}catch(e){}if(v){const p=path.join(c,v,'scripts/bootstrap-hook.js');if(fs.existsSync(p)){try{require('child_process').spawnSync('node',[p,'setup'],{stdio:'inherit',timeout:180000})}catch(e){}}}}\"",
            "timeout": 180
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs'),path=require('path'),os=require('os');const b=os.homedir()+'/.claude/plugins/cache';let c=null;for(const n of['luke','mcts','mcts-td-planner']){const d=path.join(b,n,n);if(fs.existsSync(d)){c=d;break}}if(c){let v;try{v=fs.readdirSync(c).filter(x=>{try{return fs.statSync(path.join(c,x)).isDirectory()&&/^\\d+\\.\\d+\\.\\d+$/.test(x)}catch(e){return false}}).sort((a,b)=>{const[a1,a2,a3]=a.split('.').map(Number),[b1,b2,b3]=b.split('.').map(Number);return b1-a1||b2-a2||b3-a3})[0]}catch(e){}if(v){const p=path.join(c,v,'scripts/bootstrap-hook.js');if(fs.existsSync(p)){try{require('child_process').spawnSync('node',[p,'session-start'],{stdio:'inherit',timeout:15000})}catch(e){}}}}\"",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs'),path=require('path'),os=require('os');const b=os.homedir()+'/.claude/plugins/cache';let c=null;for(const n of['luke','mcts','mcts-td-planner']){const d=path.join(b,n,n);if(fs.existsSync(d)){c=d;break}}if(c){let v;try{v=fs.readdirSync(c).filter(x=>{try{return fs.statSync(path.join(c,x)).isDirectory()&&/^\\d+\\.\\d+\\.\\d+$/.test(x)}catch(e){return false}}).sort((a,b)=>{const[a1,a2,a3]=a.split('.').map(Number),[b1,b2,b3]=b.split('.').map(Number);return b1-a1||b2-a2||b3-a3})[0]}catch(e){}if(v){const p=path.join(c,v,'scripts/bootstrap-hook.js');if(fs.existsSync(p)){try{require('child_process').spawnSync('node',[p,'session-end'],{stdio:'inherit',timeout:10000})}catch(e){}}}}\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
