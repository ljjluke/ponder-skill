{
  "name": "synthesis",
  "label": "综合",
  "stepGoal": "最终结论+风险+未决事项",
  "prompt": "整合辩论结果和推演数据,输出:\n1. 最终结论 — 推荐哪个方案及理由(引用辩论和推演中的关键证据)\n2. 推理链 — 从发散→八卦镜→方案→推演→辩论的决策路径摘要\n3. 主要风险 — 推荐方案面临的最大风险及应对\n4. 待确认事项 — 需要用户自己判断的问题清单",
  "args": ["synthesis", "ranked"],
  "schema": {
    "type": "object",
    "properties": {
      "conclusion": { "type": "string", "description": "最终结论" },
      "reasoning": { "type": "string", "description": "推理链" },
      "risk": { "type": "string", "description": "风险" },
      "pending_user_questions": { "type": "array", "items": { "type": "string" } }
    },
    "required": ["conclusion", "reasoning", "risk"]
  }
}
