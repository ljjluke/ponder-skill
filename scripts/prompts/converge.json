{
  "name": "converge",
  "label": "收敛",
  "stepGoal": "淘汰弱方案，保留3-5个最优",
  "engine_ref": "engine/converge.md",
  "tool_ref": ["scripts/mcts_guard.js diversity-challenge"],
  "prompt": "对所有方案进行对比淘汰。淘汰顺序: 边界违规→不可行→风险不可控→被其他方案全面压制。保留3-5个最优并评分(0-1),每个方案附保留理由。自检和盲点审计见 engine/mcts-converge.md。可调用 scripts/mcts_guard.js diversity-challenge 检查方案多样性",
  "args": ["plans"],
  "schema": {
    "type": "object",
    "properties": {
      "survivors": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number", "description": "0-1" },
            "reason": { "type": "string", "description": "保留理由" }
          },
          "required": ["name", "score", "reason"]
        },
        "minItems": 3
      }
    },
    "required": ["survivors"]
  }
}
