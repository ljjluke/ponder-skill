{
  "name": "bagua",
  "label": "八卦镜",
  "stepGoal": "8维度评分，量化评判",
  "prompt": "独立评估每个维度,每个:评分+依据+不确定性。每个维度都要有详细分析,不能笼统带过",
  "args": ["consensus"],
  "schema": {
    "type": "object",
    "properties": {
      "dimensions": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number", "description": "0-1" },
            "evidence": { "type": "string" },
            "uncertainty": { "type": "string" }
          },
          "required": ["name", "score", "evidence", "uncertainty"]
        },
        "minItems": 8
      },
      "key_finding": { "type": "string", "description": "关键发现" }
    },
    "required": ["dimensions", "key_finding"]
  }
}
