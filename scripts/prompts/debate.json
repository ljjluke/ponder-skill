{
  "name": "debate",
  "label": "辩论",
  "stepGoal": "各方案互相反驳，排名推荐",
  "engine_ref": "engine/debate.md",
  "agent_ref": "agents/debater.md",
  "prompt": "公平对待每个方案。每个方案起一个 agent 构建立场，定义见 agents/debater.md。分别列出优点(3-5条)和缺点(2-4条),优点引用推演中的证据,缺点指出逻辑漏洞或风险。按论证强度和证据充分性排名,输出综合推荐。五步自检清单见 engine/mcts-converge.md",
  "args": ["simulations"],
  "schema": {
    "type": "object",
    "properties": {
      "ranked": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "rank": { "type": "number" },
            "name": { "type": "string" },
            "pros": { "type": "array", "items": { "type": "string" } },
            "cons": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["rank", "name", "pros", "cons"]
        },
        "minItems": 2
      },
      "synthesis": { "type": "string", "description": "综合评述" }
    },
    "required": ["ranked", "synthesis"]
  }
}
