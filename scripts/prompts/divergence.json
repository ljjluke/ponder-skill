{
  "name": "divergence",
  "label": "发散",
  "stepGoal": "6视角审视，覆盖不同维度",
  "prompt": "从6种不同视角审视，每个视角必须产出至少1个具体洞察。\n\n视① 宏观全局: 站到最高处看整体格局、边界、系统结构\n视② 微观细节: 落到最细处看具体环节、细节中的矛盾\n视③ 时间压缩: 如果只有一天, 什么必须做?\n视④ 时间扩展: 长期看什么不变, 什么会变?\n视⑤ 顺其自然: 如果不干预, 事情会往哪里走?\n视⑥ 无我视角: 抛开个人立场, 系统最优解是什么?\n\n每个视角输出: 洞察 + 数据来源(凭什么这么说) + 假设(隐含的前提)",
  "args": ["shensi"],
  "schema": {
    "type": "object",
    "properties": {
      "perspectives": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "insight": { "type": "string" },
            "data_source": { "type": "string" },
            "assumption": { "type": "string" }
          },
          "required": ["name", "insight", "data_source", "assumption"]
        },
        "minItems": 6
      },
      "consensus": { "type": "string", "description": "6视角综合共识" }
    },
    "required": ["perspectives", "consensus"]
  }
}
